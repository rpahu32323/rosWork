
{
    "name": "rosWork",

    "dockerComposeFile": "compose.yaml",
    "service": "roswork",

    "initializeCommand": "echo \"USERNAME=$USER\nUSER_UID=$(id --user $USER)\nUSER_GID=$(id --group $USER)\n\" > .devcontainer/.env",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode-remote.remote-containers"
            ]
        }
    },

    "workspaceFolder": "/workspace/rosWork"
}